{
  "$schema": "https://railway.app/railway.schema.json",
  "services": {
    "backend": {
      "source": "backend",
      "startCommand": "python -m uvicorn server:app --host 0.0.0.0 --port ${PORT:-8000}"
    },
    "frontend": {
      "source": "frontend",
      "startCommand": "npm start"
    }
  }
}
